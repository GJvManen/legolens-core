{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legolens.local/schemas/candidate.schema.json",
  "title": "Review Candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "candidate_type",
    "title",
    "score",
    "risk",
    "review_status",
    "proposed_action",
    "evidence",
    "created_at"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[0-9]{4}$"
    },
    "candidate_type": {
      "type": "string"
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "needs_more_evidence",
        "merged"
      ]
    },
    "proposed_action": {
      "type": "string"
    },
    "evidence": {
      "type": "array"
    },
    "created_at": {
      "type": "string"
    }
  }
}
