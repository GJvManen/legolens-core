{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legolens.local/schemas/item.schema.json",
  "title": "LegoLens Item",
  "type": "object",
  "required": [
    "id",
    "canonical_id",
    "platform",
    "url",
    "title",
    "source_id",
    "source_family_id",
    "source_kind",
    "date_quality",
    "discovery",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^itm_[0-9]{5}$"
    },
    "canonical_id": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "normalized_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_id": {
      "type": "string"
    },
    "source_family_id": {
      "type": "string"
    },
    "source_kind": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "date_quality": {
      "type": "string",
      "enum": [
        "approx",
        "archive-first-seen",
        "exact",
        "exact-date",
        "exact-id",
        "unknown",
        "web-search-relative"
      ]
    },
    "thumbnail_mode": {
      "type": "string"
    },
    "flags": {
      "type": [
        "object",
        "array",
        "null"
      ]
    },
    "discovery": {
      "$ref": "discovery.schema.json"
    },
    "provenance": {
      "$ref": "provenance.schema.json"
    },
    "timeline_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "timeline_basis": {
      "type": [
        "string",
        "null"
      ]
    },
    "published_at_unknown": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "thumbnail_source": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
