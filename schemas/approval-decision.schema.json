{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LegoLens Approval Decision",
  "type": "object",
  "required": [
    "candidate_id",
    "status",
    "reviewed_by",
    "reviewed_at",
    "decision_reason"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "approved",
        "rejected",
        "duplicate",
        "needs_more_evidence"
      ]
    },
    "promoted_item_id": {
      "type": "string"
    },
    "reviewed_by": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "decision_reason": {
      "type": "string"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_available": {
      "type": "boolean"
    }
  }
}
