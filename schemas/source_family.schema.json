{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legolens.local/schemas/source_family.schema.json",
  "title": "LegoLens Source Family",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "platforms",
    "item_count",
    "exact_dates",
    "unknown_dates",
    "warnings"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "exact_dates": {
      "type": "integer",
      "minimum": 0
    },
    "unknown_dates": {
      "type": "integer",
      "minimum": 0
    },
    "latest_exact_published_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
