{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LegoLens Evidence",
  "type": "object",
  "required": [
    "evidence_id",
    "entity_type",
    "entity_id",
    "capture_status",
    "verification_status"
  ],
  "properties": {
    "evidence_id": {
      "type": "string"
    },
    "entity_type": {
      "enum": [
        "item",
        "source",
        "incident"
      ]
    },
    "entity_id": {
      "type": "string"
    },
    "source_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "archive_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "screenshot_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "preview_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "capture_method": {
      "type": "string"
    },
    "capture_status": {
      "type": "string"
    },
    "verification_status": {
      "type": "string"
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
