{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Discovery Job",
  "type": "object",
  "required": [
    "job_id",
    "label",
    "cadence",
    "method",
    "output",
    "requires_review"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "cadence": {
      "type": "string"
    },
    "targets": {
      "type": "array"
    },
    "method": {
      "type": "string"
    },
    "output": {
      "type": "string"
    },
    "requires_review": {
      "type": "boolean"
    }
  }
}
