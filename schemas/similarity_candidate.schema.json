{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Similarity Candidate",
  "type": "object",
  "required": [
    "similarity_id",
    "item_ids",
    "score",
    "signals",
    "review_status"
  ],
  "properties": {
    "similarity_id": {
      "type": "string"
    },
    "item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "score": {
      "type": "number"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_action": {
      "type": "string"
    },
    "review_status": {
      "type": "string"
    }
  }
}
