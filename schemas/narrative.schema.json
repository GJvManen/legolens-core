{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narrative Label",
  "type": "object",
  "required": [
    "id",
    "label",
    "risk"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "risk": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
